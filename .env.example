# Copy to .env and fill in keys to enable live API integrations.
# Without these, the demo runs in offline mode using seed itineraries —
# every endpoint still works end-to-end.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=

# Session housekeeping
SESSION_TTL_MINUTES=120

# CORS (comma-separated). Default '*' is fine for local dev.
CORS_ORIGINS=*

# Frontend (Vite) — point at the deployed backend in prod.
# Leave blank in dev; Vite proxies /api → http://localhost:8080.
VITE_API_BASE=
